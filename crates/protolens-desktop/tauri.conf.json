{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProtoLens",
  "version": "0.1.0",
  "identifier": "dev.protolens.app",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ProtoLens",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
